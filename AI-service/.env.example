# ============================================================
# SmartBudget AI-service 통합 환경 변수 (예시)
# .env.example을 복사하여 .env 파일을 만들고 실제 값으로 채우세요
# ============================================================

# --- Gemini LLM API (공통) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Google Custom Search (recommendation용) ---
CUSTOM_SEARCH_ENABLED=true
GOOGLE_CUSTOM_SEARCH_API_KEY=your_google_custom_search_api_key
GOOGLE_CUSTOM_SEARCH_CX=your_google_custom_search_cx

# --- 서버 설정 ---
HOST=0.0.0.0
PORT=8000
OCR_PORT=8001

# --- PostgreSQL (벡터 검색용) ---
DB_URL=jdbc:postgresql://localhost:5432/smartbudget
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=smartbudget

# --- RAG 설정 ---
RAG_USE_CHROMA=true
RAG_USE_JSONB=true
RAG_TOP_K=5
RAG_EMBEDDING_MODEL=gemini-embedding-001

# --- Tesseract OCR (필요 시) ---
TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# --- Recommendation Flask 서버 (선택) ---
RECOMMENDATION_PORT=5001
DEBUG=false
