<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartbudget.category.CategoryMapper">
    
    <resultMap id="CategoryResultMap" type="com.smartbudget.category.CategoryDTO">
        <id property="categoryId" column="category_id"/>
        <result property="name" column="name"/>
        <result property="parentId" column="parent_id"/>
    </resultMap>

    <select id="selectAllCategories" resultMap="CategoryResultMap">
        SELECT category_id, name, parent_id
        FROM projectdb.categories
        ORDER BY parent_id NULLS FIRST, name
    </select>
    
    <select id="selectRootCategories" resultMap="CategoryResultMap">
        SELECT category_id, name, parent_id
        FROM projectdb.categories
        WHERE parent_id IS NULL
        ORDER BY name
    </select>
    
    <select id="selectChildCategories" resultMap="CategoryResultMap">
        SELECT category_id, name, parent_id
        FROM projectdb.categories
        WHERE parent_id = #{parentId}
        ORDER BY name
    </select>
    
    <select id="selectCategoryById" resultMap="CategoryResultMap">
        SELECT category_id, name, parent_id
        FROM projectdb.categories
        WHERE category_id = #{categoryId}
    </select>
    
    <insert id="insertCategory" parameterType="com.smartbudget.category.CategoryDTO" useGeneratedKeys="true" keyProperty="categoryId">
        INSERT INTO projectdb.categories (name, parent_id)
        VALUES (#{name}, #{parentId})
    </insert>
    
    <update id="updateCategory" parameterType="com.smartbudget.category.CategoryDTO">
        UPDATE projectdb.categories
        SET name = #{name},
            parent_id = #{parentId}
        WHERE category_id = #{categoryId}
    </update>
    
    <delete id="deleteCategory">
        DELETE FROM projectdb.categories
        WHERE category_id = #{categoryId}
    </delete>
</mapper>
